#!/usr/bin/env php
<?php

declare(strict_types=1);

foreach ([__DIR__.'/../../../autoload.php', __DIR__.'/../vendor/autoload.php'] as $autoload) {
    if (is_file($autoload)) {
        require $autoload;
        break;
    }
}

use Symfony\Component\Console\Application;
use Symfony\Component\HttpClient\HttpClient;
use SymfonyScaffold\Installer\Github\GithubClient;
use SymfonyScaffold\Installer\InstallerCommand;

$githubClient = new GithubClient(HttpClient::create(), 'php/frankenphp');

$cmd = new InstallerCommand($githubClient);
$app = new Application('Symfony scaffold', InstallerCommand::version());
$app->addCommand($cmd);
$app->setDefaultCommand((string) $cmd->getName(), true);
$app->run();
