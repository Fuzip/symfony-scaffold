{
    "name": "fuzip/symfony-scaffold",
    "description": "Symfony docker installer",
    "type": "library",
    "keywords": ["symfony", "docker", "installer", "scaffold"],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "license": "MIT",
    "authors": [
        {
            "name": "Victor Dittiere",
            "email": "victor.dittiere@icloud.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "symfony/console": "^7.4",
        "symfony/http-client": "^7.4",
        "symfony/process": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
		"friendsofphp/php-cs-fixer": "^3.0"
	},
    "autoload": {
        "psr-4": {
            "SymfonyScaffold\\Installer\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
